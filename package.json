{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "dev": "pnpm -r run build && pnpm --filter @mini-code-cli/cli run dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/yargs": "^17.0.0",
    "esbuild": "^0.27.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@vscode/ripgrep"
    ]
  }
}
